{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Username=postgres;Password=yourpass;Database=yourdb"
  },
  "AppSettings": {
    "ShopName": "CoffeePOS",
    "TaxRate": 0.08
  },
  "SystemConfig": {
    "RunDatabaseMigrationsOnStartup": false,
    "SeedDefaultData": false
  },
  "ThemeSettings": {
    "Surface": "#FFFFFF",
    "SurfaceAlt": "#F9F6F0",
    "BrandPrimary": "#C06E52",
    "TextPrimary": "#3E2723",
    "SidebarHover": "#4E342E",
    "SidebarText": "#D7CCC8",
    "SidebarTextActive": "#FFFFFF"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Async" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "Logs/CoffeePOS_Log_.txt",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30,
                "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
              }
            }
          ]
        }
      }
    ],
    "Properties": {
      "Application": "CoffeePOS_WinForms"
    }
  }
}
